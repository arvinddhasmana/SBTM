# Copy this file to .env.demo and fill in real values.
# .env.demo is gitignored. Never commit secrets.
#
# Used by:
#   scripts/azure/provision-azure.sh demo   (auto-loads .env.demo)
#   scripts/azure/setup-keyvault.sh         (run with ENV_FILE=.env.demo)
#   scripts/azure/setup-db.sh               (run with ENV_FILE=.env.demo)
#
# Demo values can be weaker than production (still ≥32 chars JWT, ≥12 char DB
# password — enforced by setup-keyvault.sh), but MUST NOT be reused in prod.

JWT_SECRET=<generate random 32+ chars: openssl rand -base64 48>
DB_PASSWORD=<same as POSTGRES_ADMIN_PASSWORD used during provisioning>
FCM_SERVER_KEY=<from Firebase Console (demo project)>
TWILIO_AUTH_TOKEN=<from Twilio Console (test credentials are fine)>
TWILIO_ACCOUNT_SID=<from Twilio Console (test credentials are fine)>
DATABASE_URL=postgresql://sbtmadmin:<password>@<postgres-fqdn>:5432/sbms?sslmode=require
REDIS_URL=rediss://:<redis-primary-key>@<redis-host>:6380
AZURE_STORAGE_CONNECTION_STRING=<from demo storage account>
APPLICATIONINSIGHTS_CONNECTION_STRING=<from demo App Insights>

# ─────────────────────────────────────────────────────────────────────
# Fetch Azure-backed values after provisioning (resource group: sbtm-demo-rg):
#
#   RG=sbtm-demo-rg
#
#   az postgres flexible-server list -g $RG --query "[0].fullyQualifiedDomainName" -o tsv
#   az redis list -g $RG --query "[0].hostName" -o tsv
#   REDIS_NAME=$(az redis list -g $RG --query "[0].name" -o tsv)
#   az redis list-keys -g $RG -n $REDIS_NAME --query primaryKey -o tsv
#   STORAGE_NAME=$(az storage account list -g $RG --query "[0].name" -o tsv)
#   az storage account show-connection-string -g $RG -n $STORAGE_NAME --query connectionString -o tsv
#   AI_NAME=$(az monitor app-insights component list -g $RG --query "[0].name" -o tsv)
#   az monitor app-insights component show -g $RG -a $AI_NAME --query connectionString -o tsv
# ─────────────────────────────────────────────────────────────────────
