# Application
PORT=3005
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=video_service
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Storage
STORAGE_TYPE=minio
STORAGE_BASE_URL=http://localhost:3005

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=videos

# Presigned URL Expiry (in seconds)
PRESIGNED_URL_EXPIRY=3600

# CORS
CORS_ORIGIN=*
