# Video Service — Local Development Environment
# Copy this to .env and fill in required values.
# NEVER commit .env — it is listed in .gitignore.

# Application
PORT=3005
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme_local
DB_DATABASE=video_service
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Storage
STORAGE_TYPE=minio
# Base URL used when building presigned URLs pointing back to this service
STORAGE_BASE_URL=http://localhost:3005

# MinIO — generate credentials with: openssl rand -hex 16
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=changeme_minio_access_key
MINIO_SECRET_KEY=changeme_minio_secret_key
MINIO_BUCKET_NAME=videos

# Presigned URL expiry in seconds (default: 1 hour)
PRESIGNED_URL_EXPIRY=3600

# CORS
CORS_ORIGIN=*
