# API Gateway — Local Development Environment
# Copy this to .env and fill in required values.
# NEVER commit .env — it is listed in .gitignore.

# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme_local
DB_DATABASE=sbms

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=changeme_replace_with_32_char_random_string
JWT_EXPIRATION=24h

# Internal service-to-service auth
# Must match INTERNAL_SERVICE_SECRET in gps-tracking and emergency-alerts
INTERNAL_SERVICE_SECRET=changeme_replace_with_32_char_random_string

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# HTTP Client
HTTP_TIMEOUT=10000

# Downstream Service URLs (required — no defaults)
GPS_SERVICE_URL=http://localhost:3002
ALERTS_SERVICE_URL=http://localhost:3003
PRESENCE_SERVICE_URL=http://localhost:3004
VIDEO_SERVICE_URL=http://localhost:3005
STUDENT_SERVICE_URL=http://localhost:3006
COMPLIANCE_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008

# OSRM (required — no default)
OSRM_BASE_URL=http://localhost:5000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Business policy (optional — defaults shown)
# INVITATION_EXPIRY_HOURS=72
# COOKIE_MAX_AGE_HOURS=24
# ALERT_CONFIRMATION_TIMEOUT_MS=120000
# ALERT_BOARD_ESCALATION_MS=300000
# ALERT_OSTA_ESCALATION_MS=900000
