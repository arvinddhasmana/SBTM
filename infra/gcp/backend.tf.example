# Backend Configuration for Terraform State
# This file should be created per environment

# For Demo:
# terraform {
#   backend "gcs" {
#     bucket = "YOUR_PROJECT_ID-tfstate"
#     prefix = "sbtm/demo"
#   }
# }

# For Production:
# terraform {
#   backend "gcs" {
#     bucket = "YOUR_PROJECT_ID-tfstate"
#     prefix = "sbtm/production"
#   }
# }

# Run this command to create the state bucket:
# gsutil mb -p YOUR_PROJECT_ID -l us-central1 gs://YOUR_PROJECT_ID-tfstate
# gsutil versioning set on gs://YOUR_PROJECT_ID-tfstate
