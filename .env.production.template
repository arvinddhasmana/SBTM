JWT_SECRET=<generate random 32+ chars>
DB_PASSWORD=<same as POSTGRES_ADMIN_PASSWORD used during provisioning>
DATABASE_URL=postgresql://sbtmadmin:<password>@<postgres-fqdn>:5432/sbms?sslmode=require
REDIS_URL=rediss://:<redis-primary-key>@<redis-host>:6380
FCM_SERVER_KEY=<from Firebase Console>
TWILIO_AUTH_TOKEN=<from Twilio Console>
TWILIO_ACCOUNT_SID=<from Twilio Console>
AZURE_STORAGE_CONNECTION_STRING=<from storage account>
APPLICATIONINSIGHTS_CONNECTION_STRING=<from App Insights>

/*
Where to fetch Azure-backed values after provisioning:

postgres-fqdn:
az postgres flexible-server list -g <resource-group> --query "[0].fullyQualifiedDomainName" -o tsv
redis-host and redis key:
az redis list -g <resource-group> --query "[0].name" -o tsv
az redis list -g <resource-group> --query "[0].hostName" -o tsv
az redis list-keys -g <resource-group> -n <redis-name> --query primaryKey -o tsv
storage connection string:
az storage account list -g <resource-group> --query "[0].name" -o tsv
az storage account show-connection-string -g <resource-group> -n <storage-name> --query connectionString -o tsv
app insights connection string:
az monitor app-insights component list -g <resource-group> --query "[0].name" -o tsv
az monitor app-insights component show -g <resource-group> -a <appinsights-name> --query connectionString -o tsv
*/