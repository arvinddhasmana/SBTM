# SBTM Driver App Environment Configuration
# Copy this file to .env and update the values.

# ─── API Server URL ─────────────────────────────────────────────
# Point this to the backend API gateway. Use one of these patterns:
#
# Local (Android Emulator):  http://10.0.2.2:3001/api/v1
# Local (iOS Simulator):     http://localhost:3001/api/v1
# LAN (real phone on WiFi):  http://192.168.x.x:3001/api/v1
# ngrok tunnel:               https://xxxx-xxxx.ngrok-free.app/api/v1
# Cloud server:               https://your-server.example.com/api/v1
#
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api/v1

# ─── Google Maps Android API key ────────────────────────────────
# Required for `react-native-maps` on Android standalone builds.
# Without it, MapView crashes with IllegalStateException.
# For cloud (EAS) builds the key comes from an EAS secret of the same name —
# you only need to set this locally if you build with `expo run:android`.
# Create one at: https://console.cloud.google.com/google/maps-apis
# Restrict by package `com.sbtm.driver` + your keystore SHA-1.
GOOGLE_MAPS_ANDROID_API_KEY=
