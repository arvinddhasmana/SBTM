# =============================================================================
# SBTM Hybrid Development Environment Variables
# =============================================================================
# Copy this file to .env in the root directory or individual service directories
# when running in Hybrid mode (Docker infra + local app services).
#
# Usage: cp .env.hybrid.template .env

# --- Database (Postgres via Docker on port 5433) ---
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=mysecretpassword
DB_DATABASE=sbms
DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5433/sbms

# --- Redis (via Docker on default port) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- OSRM (via Docker on port 5000) ---
OSRM_BASE_URL=http://localhost:5000

# --- API Gateway ---
PORT=3001
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
# PII encryption key (base64-encoded 32 bytes) — required by api-gateway at boot
SBTM_PII_KEY=A86xdo4A+EWjTJ2zwz6JNIt5Ck8ncd9Ut3rkgq7JBD8=
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
HTTP_TIMEOUT=10000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Service URLs (all running on localhost in Hybrid mode) ---
GPS_SERVICE_URL=http://localhost:3002
ALERTS_SERVICE_URL=http://localhost:3003
PRESENCE_SERVICE_URL=http://localhost:3004
VIDEO_SERVICE_URL=http://localhost:3005
STUDENT_SERVICE_URL=http://localhost:3006
COMPLIANCE_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
INTERNAL_SERVICE_SECRET=dev_internal_secret_change_me_in_prod

# --- Admin Dashboard (Vite) ---
VITE_API_URL=http://localhost:3001
# Set to 'true' to enable mock mode (no backend required)
# VITE_USE_MOCK=true
